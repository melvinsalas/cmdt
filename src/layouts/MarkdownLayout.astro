---
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;
---

<Layout
  title={frontmatter?.title ?? "Post"}
  description={frontmatter?.description}
>
  <main class="mx-auto max-w-[896px] px-4 py-8">
    <article class="markdown-content">
      <header class="mb-8 border-b border-slate-200 pb-4">
        <h1>{frontmatter?.title}</h1>
        {
          frontmatter?.description && (
            <p class="m-0 text-slate-600">{frontmatter.description}</p>
          )
        }
        {
          frontmatter?.date && (
            <p class="mt-2 mb-0 text-sm text-slate-500">{frontmatter.date}</p>
          )
        }
      </header>

      <slot />
    </article>
  </main>
</Layout>
