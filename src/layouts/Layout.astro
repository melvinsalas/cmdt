---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
		<header class="border-b border-slate-200 bg-white px-4 py-3">
			<nav class="mx-auto flex w-full max-w-5xl items-center gap-4 text-sm font-medium text-slate-700">
				<a class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" href="/">Home</a>
				<div class="group relative">
					<button class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" type="button">Transparencia</button>
					<div class="invisible absolute left-0 top-full z-10 min-w-56 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
						<div class="rounded-md border border-slate-200 bg-white p-1 shadow-sm">
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/actas">Actas Municipales</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/planes">Planes de Gobierno</a>
						</div>
					</div>
				</div>
			</nav>
		</header>
		<slot />
		<script>
			document.querySelectorAll('a[href]').forEach(link => {
				link.setAttribute('target', '_blank');
				link.setAttribute('rel', 'noopener noreferrer');
			});
		</script>
	</body>
</html>
