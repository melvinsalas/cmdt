---
import DataTable from './DataTable.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type ArchiveType = CollectionEntry<'archive'>['data']['type'];

type Props = {
	baseUri: string;
	types: ArchiveType[];
	emptyMessage?: string;
	limit?: number;
	enableYearFilter?: boolean;
	heading?: string;
};

const {
	baseUri,
	types,
	emptyMessage = 'No hay registros publicados.',
	limit,
	enableYearFilter = true,
	heading,
}: Props = Astro.props;

const normalizeBaseUri = (value: string): string => {
	const trimmed = value.trim();
	if (!trimmed) return '';
	const withoutTrailingSlash = trimmed.endsWith('/') ? trimmed.slice(0, -1) : trimmed;
	return withoutTrailingSlash.startsWith('/') ? withoutTrailingSlash : `/${withoutTrailingSlash}`;
};

const normalizedBaseUri = normalizeBaseUri(baseUri);
const entries = await getCollection('archive', ({ data }) => types.includes(data.type));

const data = entries
	.map((entry) => {
		const routeSlug = entry.id.replace(/\.(md|mdx)$/, '');

		return {
			title: entry.data.title,
			date: new Date(entry.data.date),
			type: entry.data.type,
			href: encodeURI(`${normalizedBaseUri}/${routeSlug}/`),
		};
	})
	.sort((a, b) => b.date.getTime() - a.date.getTime());

const safeLimit = Number.isInteger(limit) && (limit as number) > 0 ? (limit as number) : undefined;
const visibleData = safeLimit ? data.slice(0, safeLimit) : data;
---

<DataTable data={visibleData} emptyMessage={emptyMessage} showYearFilter={enableYearFilter} heading={heading} />
