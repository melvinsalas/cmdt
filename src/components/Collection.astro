---
import DataTable from './DataTable.astro';

type CollectionName = 'actas' | 'concursos' | 'licitaciones';

type Props = {
	collection: CollectionName;
	baseUri: string;
	emptyMessage?: string;
	limit?: number;
};

type MarkdownModule = {
	frontmatter: {
		title: string;
		date: string | Date;
		type?: string;
		file?: string;
	};
};

type MarkdownModuleMap = Record<string, MarkdownModule>;

const {
	collection,
	baseUri,
	emptyMessage = 'No hay registros publicados.',
	limit,
}: Props = Astro.props;

const modules =
	collection === 'actas'
		? (import.meta.glob('../pages/transparencia/actas/*.{md,mdx}', { eager: true }) as MarkdownModuleMap)
		: collection === 'concursos'
			? (import.meta.glob('../pages/transparencia/concursos/*.{md,mdx}', { eager: true }) as MarkdownModuleMap)
			: (import.meta.glob('../pages/transparencia/licitaciones/*.{md,mdx}', { eager: true }) as MarkdownModuleMap);

const data = Object.entries(modules)
	.map(([filePath, entry]) => {
		const fileName = filePath.split('/').pop() ?? '';
		const slug = fileName.replace(/\.(md|mdx)$/, '');

		return {
			title: entry.frontmatter.title,
			date: new Date(entry.frontmatter.date),
			type: entry.frontmatter.type,
			file: entry.frontmatter.file,
			href: encodeURI(`${baseUri}/${slug}/`),
		};
	})
	.sort((a, b) => b.date.getTime() - a.date.getTime());

const safeLimit = Number.isInteger(limit) && (limit as number) > 0 ? (limit as number) : undefined;
const visibleData = safeLimit ? data.slice(0, safeLimit) : data;
---

<DataTable data={visibleData} emptyMessage={emptyMessage} />
