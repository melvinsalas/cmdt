---
import { getCollection } from 'astro:content';
import DataTable from './DataTable.astro';

type CollectionName = 'actas' | 'concursos' | 'licitaciones';

type Props = {
	collection: CollectionName;
	baseUri: string;
	emptyMessage?: string;
	limit?: number;
};

const {
	collection,
	baseUri,
	emptyMessage = 'No hay registros publicados.',
	limit,
}: Props = Astro.props;

const entries = await getCollection(collection);

const data = entries
	.map((entry) => ({
		title: entry.data.title,
		date: entry.data.date,
		type: entry.data.type,
		file: entry.data.file,
		href: encodeURI(`${baseUri}/${entry.id.replace(/\.(md|mdx)$/, '')}/`),
	}))
	.sort((a, b) => b.date.getTime() - a.date.getTime());

const safeLimit = Number.isInteger(limit) && (limit as number) > 0 ? (limit as number) : undefined;
const visibleData = safeLimit ? data.slice(0, safeLimit) : data;
---

<DataTable data={visibleData} emptyMessage={emptyMessage} />
