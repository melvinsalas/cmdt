---
import DataTable from './DataTable.astro';
import { getCollection } from 'astro:content';

type CollectionName = 'actas' | 'concursos' | 'licitaciones';

type Props = {
	baseUri: string;
	emptyMessage?: string;
	limit?: number;
};

const {
	baseUri,
	emptyMessage = 'No hay registros publicados.',
	limit,
}: Props = Astro.props;

const normalizeBaseUri = (value: string): string => {
	const trimmed = value.trim();
	if (!trimmed) return '';
	const withoutTrailingSlash = trimmed.endsWith('/') ? trimmed.slice(0, -1) : trimmed;
	return withoutTrailingSlash.startsWith('/') ? withoutTrailingSlash : `/${withoutTrailingSlash}`;
};

const normalizedBaseUri = normalizeBaseUri(baseUri);
const collectionKey = normalizedBaseUri.split('/').filter(Boolean).at(-1) as CollectionName | undefined;
const entries = collectionKey ? await getCollection(collectionKey) : [];

const data = entries
	.map((entry) => {
		const slug = entry.id.replace(/\.(md|mdx)$/, '');

		return {
			title: entry.data.title,
			date: new Date(entry.data.date),
			type: entry.data.type,
			file: entry.data.file,
			href: encodeURI(`${normalizedBaseUri}/${slug}/`),
		};
	})
	.sort((a, b) => b.date.getTime() - a.date.getTime());

const safeLimit = Number.isInteger(limit) && (limit as number) > 0 ? (limit as number) : undefined;
const visibleData = safeLimit ? data.slice(0, safeLimit) : data;
---

<DataTable data={visibleData} emptyMessage={emptyMessage} />
