---
const { brand = 'Home' } = Astro.props;
---

<header class="border-b border-slate-200 bg-white px-4 py-3">
	<nav class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 text-sm font-medium text-slate-700">
		<a class="rounded px-2 py-1 text-slate-900 hover:bg-slate-100" href="/">{brand}</a>

		<div class="flex items-center gap-2">
			<div class="group relative">
				<button class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" type="button">Transparencia</button>
				<div class="invisible absolute right-0 top-full z-10 min-w-56 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
					<div class="rounded-md border border-slate-200 bg-white p-1">
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/actas">Actas Municipales</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/planes">Planes de Gobierno</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/licitaciones">Licitaciones</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/transparencia/concursos">Concursos</a>
					</div>
				</div>
			</div>

			<div class="group relative">
				<button class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" type="button">Gestión</button>
				<div class="invisible absolute right-0 top-full z-10 min-w-56 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
					<div class="rounded-md border border-slate-200 bg-white p-1">
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/gestion/formularios/">Formularios</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/gestion/ambiental/">Gestión Ambiental</a>
						<a class="block rounded px-3 py-2 text-slate-700 hover:bg-slate-100 hover:text-slate-900" href="/gestion/desarrollo-humano/">Desarrollo Humano</a>
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>
