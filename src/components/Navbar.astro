---
const { brand = 'Home' } = Astro.props;

import MenuItem from './MenuItem.astro';

const transparenciaItems = [
	{ href: '/transparencia/actas', title: 'Actas Municipales', description: 'Sesiones, acuerdos y documentos oficiales.', icon: 'document' },
	{ href: '/transparencia/planes', title: 'Planes de Gobierno', description: 'Metas, programas y seguimiento institucional.', icon: 'chart' },
	{ href: '/transparencia/licitaciones', title: 'Licitaciones', description: 'Procesos de contratación y expedientes abiertos.', icon: 'briefcase' },
	{ href: '/transparencia/concursos', title: 'Concursos', description: 'Convocatorias, bases y resultados de concursos.', icon: 'users' },
	{ href: 'https://www.sicop.go.cr/moduloPcont/expedientesElectronicos.jsp?code=5b50159fd3121462b1c225df56cb576a6748d82660198ce2b542b60b71b14f7a636262775d3921e40ed145a357ca401ec7c84d3b3379023e6a103591d5d8cba7304f5a798bb8a68273d8228cbf092c0f7645687eabc5552a56bb2bad877b489494e1a891333eb56bcc0a371d12ac94987580b427cae622234462e448186da624', title: 'Expediente', description: 'Acceso al sistema externo de expedientes electrónicos.', icon: 'external', external: true },
];

const gestionItems = [
	{ href: '/gestion/formularios/', title: 'Formularios', description: 'Trámites y solicitudes para la ciudadanía.', icon: 'form' },
	{ href: '/gestion/ambiental/', title: 'Gestión Ambiental', description: 'Iniciativas, reportes y acciones ambientales.', icon: 'leaf' },
	{ href: '/gestion/desarrollo-humano/', title: 'Desarrollo Humano', description: 'Programas sociales y atención comunitaria.', icon: 'people' },
];
---

<header class="border-b border-slate-200 bg-white px-4 py-3">
	<nav class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 text-sm font-medium text-slate-700">
		<a class="rounded px-2 py-1 text-slate-900 hover:bg-slate-100" href="/">{brand}</a>

		<div class="flex items-center gap-2">
			<div class="group relative">
				<button class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" type="button">Transparencia</button>
				<div class="invisible absolute right-0 top-full z-10 min-w-80 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
					<div class="rounded-xl border border-slate-200 bg-white p-2 shadow-lg shadow-slate-200/60">
						{transparenciaItems.map((item) => <MenuItem {...item} />)}
					</div>
				</div>
			</div>

			<div class="group relative">
				<button class="rounded px-2 py-1 hover:bg-slate-100 hover:text-slate-900" type="button">Gestión</button>
				<div class="invisible absolute right-0 top-full z-10 min-w-80 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
					<div class="rounded-xl border border-slate-200 bg-white p-2 shadow-lg shadow-slate-200/60">
						{gestionItems.map((item) => <MenuItem {...item} />)}
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>
