---
const { brand = "Home" } = Astro.props;

import MenuItem from "./MenuItem.astro";
import { menus } from "../data/menus";
import { Menu, X } from "@lucide/astro";
---

<header class="relative z-[60] border-b border-slate-200 bg-white px-4 py-3">
	<nav
		class="mx-auto flex w-full max-w-5xl flex-wrap items-start justify-between gap-4 text-sm font-medium text-slate-700"
	>
		<a
			class="self-center rounded px-2 py-1 text-slate-900 hover:bg-slate-100"
			href="/">{brand}</a
		>
		<details class="group relative ml-auto md:hidden" id="mobile-menu">
			<summary
				class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-md border border-slate-200 text-slate-700 marker:content-none hover:bg-slate-100 hover:text-slate-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-slate-400"
			>
				<Menu aria-hidden="true" class="h-5 w-5 group-open:hidden" />
				<X aria-hidden="true" class="hidden h-5 w-5 group-open:block" />
			</summary>

			<div
				class="fixed right-0 top-0 z-[80] h-full w-[min(22rem,calc(100vw-2rem))] overflow-y-auto border-l border-slate-200 bg-white px-4 py-3"
				id="mobile-nav-accordion"
			>
				<div class="mb-4 flex items-center justify-end">
					<button
						id="mobile-close-btn"
						class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-slate-200 text-slate-700 hover:bg-slate-100 hover:text-slate-900"
						aria-label="Cerrar menú"
					>
						<X aria-hidden="true" class="h-5 w-5" />
					</button>
				</div>
				{
					menus.map((menu, index) => (
						<div class:list={[index > 0 && "mt-4"]}>
							<p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wide text-slate-400">
								{menu.title}
							</p>
							{menu.items.map((item) => (
								<MenuItem {...item} />
							))}
						</div>
					))
				}
			</div>
		</details>

		<div class="hidden items-center gap-2 md:flex" id="desktop-nav-menus">
			{
				menus.map((menu) => (
					<details class="group relative">
						<summary class="inline-flex cursor-pointer list-none items-center rounded px-2 py-1 marker:content-none hover:bg-slate-100 hover:text-slate-900">
							<span>{menu.title}</span>
						</summary>
						<div class="animate-surface absolute right-0 top-full z-[70] min-w-80 pt-2">
							<div class="rounded-xl border border-slate-200 bg-white p-2">
								{menu.items.map((item) => (
									<MenuItem {...item} />
								))}
							</div>
						</div>
					</details>
				))
			}
		</div>
	</nav>
</header>

<div
	id="mobile-backdrop"
	class="fixed inset-0 z-[70] hidden bg-black/50 md:hidden"
>
</div>

<script>
	const desktopWrapper =
		document.querySelector<HTMLElement>("#desktop-nav-menus");

	const getDirectDetails = (container: HTMLElement) => [
		...container.querySelectorAll<HTMLDetailsElement>(":scope > details"),
	];

	const closeSiblings = (
		items: HTMLDetailsElement[],
		current: HTMLDetailsElement,
	) => {
		items.forEach((item) => {
			if (item !== current) item.open = false;
		});
	};

	if (desktopWrapper) {
		const desktopMenus = getDirectDetails(desktopWrapper);

		desktopMenus.forEach((menu) => {
			menu.addEventListener("mouseenter", () => {
				closeSiblings(desktopMenus, menu);
				menu.open = true;
			});

			menu.addEventListener("toggle", () => {
				if (menu.open) closeSiblings(desktopMenus, menu);
			});
		});

		desktopWrapper.addEventListener("mouseleave", () => {
			desktopMenus.forEach((menu) => (menu.open = false));
		});
	}

	const mobileMenu =
		document.querySelector<HTMLDetailsElement>("#mobile-menu");
	const backdrop = document.querySelector<HTMLElement>("#mobile-backdrop");
	const closeBtn =
		document.querySelector<HTMLButtonElement>("#mobile-close-btn");

	const closeMobileMenu = () => {
		if (mobileMenu) mobileMenu.open = false;
	};

	if (mobileMenu && backdrop) {
		mobileMenu.addEventListener("toggle", () => {
			backdrop.classList.toggle("hidden", !mobileMenu.open);
			document.body.style.overflow = mobileMenu.open ? "hidden" : "";
		});
		backdrop.addEventListener("click", closeMobileMenu);
	}

	closeBtn?.addEventListener("click", closeMobileMenu);
</script>
