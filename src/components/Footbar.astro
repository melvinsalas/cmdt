---
import { menus } from "../data/menus";
import logo from "../assets/logo.png";
import { ExternalLink } from "@lucide/astro";

const year = new Date().getFullYear();
---

<footer class="paper-surface-strong mt-10 px-4 py-8 text-sm text-slate-700">
	<div class="mx-auto w-full max-w-5xl">
		<div
			class="flex flex-col gap-y-12 lg:flex-row lg:items-start"
		>
			<section class="px-2 py-1 lg:max-w-[17rem] lg:flex-none lg:px-4 lg:py-2">
				<a
					href="/"
					class="inline-flex flex-col items-start gap-3 text-slate-900"
				>
					<img
						src={logo.src}
						alt="Logo Municipalidad de Tucurrique"
						class="h-14 w-14 object-contain"
					/>
					<div>
						<p class="text-lg font-semibold leading-tight">
							Concejo Municipal del Distrito de Tucurrique
						</p>
						<p
							class="mt-1 text-xs uppercase tracking-[0.2em] text-slate-500"
						>
							Gobierno local
						</p>
					</div>
				</a>
			</section>

			<section class="px-2 py-1 lg:min-w-0 lg:flex-1 lg:px-4 lg:py-2">
				<div class="flex flex-wrap gap-x-8 gap-y-6">
					{
						menus.map((section) => (
							<section
								aria-labelledby={`footbar-${section.id}`}
								class="basis-full sm:basis-[calc(50%-1rem)] xl:basis-[calc(25%-1.5rem)]"
							>
								<h3
									id={`footbar-${section.id}`}
									class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500"
								>
									{section.title}
								</h3>
								<ul class="mt-3 space-y-2">
									{section.items.map((item) => (
										<li>
											<a
												class="inline-flex items-center gap-1.5 text-sm text-slate-700 transition hover:text-slate-900 hover:underline"
												href={item.href}
												target={
													item.external
														? "_blank"
														: undefined
												}
												rel={
													item.external
														? "noopener noreferrer"
														: undefined
												}
											>
												<span>{item.title}</span>
												{item.external ? (
													<ExternalLink
														aria-hidden="true"
														class="h-3.5 w-3.5 shrink-0 text-slate-500"
													/>
												) : null}
											</a>
										</li>
									))}
								</ul>
							</section>
						))
					}
				</div>
			</section>
		</div>

		<div
			class="mt-6 flex justify-end pt-5 text-right text-xs text-slate-500"
		>
			<p class="flex flex-wrap justify-end gap-x-1 gap-y-0.5">
				<span class="whitespace-nowrap">Concejo Municipal del Distrito de Tucurrique ·</span>
				<span class="whitespace-nowrap">{year}. Todos los derechos reservados.</span>
			</p>
		</div>
	</div>
</footer>
