---
import {
	Award,
	Building,
	ClipboardPen,
	Cookie,
	ExternalLink,
	Eye,
	FolderOpen,
	GlobeCheck,
	Heart,
	Landmark,
	Mail,
	Map,
	PhoneCall,
	ThumbsUp,
	TreeDeciduous,
	User,
	UserRoundCheck,
} from '@lucide/astro';

type IconName = 'award' | 'map' | 'building' | 'user' | 'folder-open' | 'clipboard-pen' | 'tree-deciduous' | 'user-round-check' | 'eye' | 'landmark' | 'heart' | 'phone-call' | 'cookie' | 'globe-check' | 'mail' | 'thumbs-up';

const { href, title, description, icon, external = false } = Astro.props as {
	href: string;
	title: string;
	description?: string;
	icon: IconName;
	external?: boolean;
};

const iconMap = {
	award: Award,
	map: Map,
	building: Building,
	user: User,
	'folder-open': FolderOpen,
	'clipboard-pen': ClipboardPen,
	'tree-deciduous': TreeDeciduous,
	'user-round-check': UserRoundCheck,
	eye: Eye,
	landmark: Landmark,
	heart: Heart,
	'phone-call': PhoneCall,
	cookie: Cookie,
	'globe-check': GlobeCheck,
	mail: Mail,
	'thumbs-up': ThumbsUp,
} satisfies Record<IconName, typeof Award>;

const IconComponent = iconMap[icon];
const hasDescription = Boolean(description);
---

<a
	class:list={[
		'group flex gap-3 rounded-lg px-3 py-2 text-slate-700 transition hover:bg-slate-100 hover:text-slate-900',
		hasDescription ? 'items-start' : 'items-center',
	]}
	href={href}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
>
	<span class:list={[
		'flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-slate-100 text-slate-700 transition group-hover:bg-slate-200 group-hover:text-slate-900',
		hasDescription ? 'mt-0.5' : 'mt-0',
	]}>
		<IconComponent aria-hidden="true" class="h-4.5 w-4.5" />
	</span>

	<span class="min-w-0 flex-1">
		<span class="block text-sm font-semibold leading-5 text-slate-900">{title}</span>
		{description ? <span class="mt-0.5 block text-xs leading-5 text-slate-500">{description}</span> : null}
	</span>

	{external ? (
		<ExternalLink aria-hidden="true" class="h-4 w-4 shrink-0 text-slate-400 self-center" />
	) : null}
</a>