---
import { formatDateEs } from '../utils/date';

interface Props {
	title: string;
	date: string;
	url: string;
	type: 'ordinaria' | 'extraordinaria';
}

const { title, date, url, type } = Astro.props;
const displayDate = formatDateEs(date);
const fileName = (() => {
	const parts = url.split('/').filter(Boolean);
	const last = parts[parts.length - 1] ?? 'archivo';
	return decodeURIComponent(last);
})();
const safeUrl = encodeURI(url);
---

<li class="group rounded-xl border border-slate-200 bg-white p-5">
	<div class="flex flex-wrap items-start justify-between gap-3">
		<div class="min-w-0">
			<strong class="line-clamp-2 text-base font-semibold text-slate-900">{title}</strong>
			<div class="mt-2 inline-flex items-center gap-2 text-sm text-slate-500">
				<span
					class:list={[
						'inline-block rounded-full px-2.5 py-1 text-xs font-semibold capitalize ring-1 ring-inset',
						type === 'ordinaria' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800',
					]}
				>
					{type}
				</span>
				{displayDate}
			</div>
		</div>
		<div class="flex flex-col items-start gap-2">
			<a
				class="btn-primary"
				href={safeUrl}
				target="_blank"
				rel="noopener noreferrer"
			>
				{fileName}
			</a>
		</div>
	</div>
</li>
