---
import { formatDateEs } from '../utils/date';

interface Props {
	title: string;
	date: string;
	url: string;
	type: 'ordinaria' | 'extraordinaria';
}

const { title, date, url, type } = Astro.props;
const displayDate = formatDateEs(date);
---

<li class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
	<div class="flex flex-wrap items-center gap-2">
		<span
			class:list={[
				'inline-block rounded-full px-2 py-1 text-xs font-semibold capitalize',
				type === 'ordinaria' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800',
			]}
		>
			{type}
		</span>
		<strong class="text-slate-900">{title}</strong>
	</div>
	<div class="mt-2 text-sm text-slate-600">{displayDate}</div>
	<a class="mt-2 inline-block text-sm text-blue-700 hover:underline" href={url}>
		Ver archivo
	</a>
</li>
