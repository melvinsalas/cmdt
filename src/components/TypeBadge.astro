---
import { getTypeVariant } from '../utils/type-colors';

interface Props {
	type?: string;
}

const { type } = Astro.props;
const variant = getTypeVariant(type);
---

{type ? (
	<span
		class:list={[
			'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset',
			variant.badge,
		]}
	>
		{variant.label}
	</span>
) : null}
