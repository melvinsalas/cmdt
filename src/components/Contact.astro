---
import Mail from "@lucide/astro/icons/mail";
import Phone from "@lucide/astro/icons/phone";

type Props = {
	name: string;
	role: string;
	email?: string;
	phone?: string;
};

const { name, role, email, phone }: Props = Astro.props;
---

<div class="flex flex-col gap-0.5 py-2 border-b border-slate-100 last:border-0">
	<span class="text-sm font-semibold text-slate-900">{name}</span>
	<span class="text-xs text-slate-500">{role}</span>
	<div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-0.5">
		{email && (
			<a href={`mailto:${email}`} class="flex items-center gap-1 text-xs text-blue-600 hover:underline">
				<Mail size={12} />{email}
			</a>
		)}
		{phone && (
			<span class="flex items-center gap-1 text-xs text-slate-600">
				<Phone size={12} />{phone}
			</span>
		)}
	</div>
</div>