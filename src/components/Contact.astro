---
type Props = {
	name: string;
	role: string;
	email?: string;
	phone?: string;
};

const { name, role, email, phone }: Props = Astro.props;
---

<article class="my-2 rounded-md border border-slate-200 bg-white p-3 leading-snug">
	<h2 class="m-0 text-base font-semibold text-slate-900">{name}</h2>
	<p class="mt-0.5 mb-0 text-sm text-slate-700">{role}</p>

	{email && (
		<p class="mt-1 mb-0 text-sm">
			<a href={`mailto:${email}`} class="break-all">{email}</a>
		</p>
	)}

	{phone && <p class="mt-1 mb-0 text-sm text-slate-800">Tel. {phone}</p>}
</article>