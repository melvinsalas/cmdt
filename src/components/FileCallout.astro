---
import { FileSize } from '../utils/file-size';
import { getTypeVariant } from '../utils/type-colors';
import { FileSpreadsheet, FileText, Package, ShieldQuestionMark } from '@lucide/astro';

type Props = {
	href: string;
	type?: string;
};

const { href, type }: Props = Astro.props;

const fileName = (() => {
	const last = href.split("/").filter(Boolean).pop();
	if (!last) return "Archivo";
	return decodeURIComponent(last);
})();

const sizeText = FileSize.getFromPublicHref(href);
const { callout, calloutIcon } = getTypeVariant(type);

const extension = fileName.split('.').pop()?.toLowerCase();
const Icon = (() => {
	if (extension === 'xls' || extension === 'xlsx') return FileSpreadsheet;
	if (extension === 'doc' || extension === 'docx' || extension === 'pdf') return FileText;
	if (extension === 'zip') return Package;
	return ShieldQuestionMark;
})();
---

<aside
	class:list={[
		"my-3 flex items-center gap-3 border-l-4 p-4 text-slate-900",
		callout,
	]}
	role="note"
>
	<Icon aria-hidden="true" class:list={['h-5 w-5 shrink-0', calloutIcon]} />
	<span class="min-w-0">
		<a href={href} target="_blank" rel="noopener noreferrer" class="file-callout-link block text-lg">
			{fileName}
		</a>
		<span class="block whitespace-nowrap font-mono text-sm text-slate-600">{sizeText}</span>
	</span>
</aside>
