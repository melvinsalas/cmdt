---
import { existsSync, statSync } from 'node:fs';
import path from 'node:path';

type Props = {
	href: string;
};

const { href }: Props = Astro.props;

const toLocalFilePath = (urlPath: string) => {
	if (!urlPath.startsWith('/')) return null;
	const safePath = urlPath.replace(/^\/+/, '');
	return path.join(process.cwd(), 'public', safePath);
};

const formatSize = (bytes: number) => {
	const kb = bytes / 1024;
	if (kb < 1024) return `${kb.toFixed(1)} KB`;
	const mb = kb / 1024;
	return `${mb.toFixed(2)} MB`;
};

const localPath = toLocalFilePath(href);

const fileName = (() => {
	const last = href.split('/').filter(Boolean).pop();
	if (!last) return 'Archivo';
	return decodeURIComponent(last);
})();

let sizeText = 'Tamaño no disponible';
if (localPath && existsSync(localPath)) {
	const stats = statSync(localPath);
	if (stats.isFile()) {
		sizeText = formatSize(stats.size);
	}
}
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	class="my-2 block rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-900 no-underline transition hover:border-blue-300 hover:bg-blue-50 hover:no-underline"
	style="text-decoration: none;"
>
	<span class="inline-flex items-center gap-2.5">
		<span aria-hidden="true">📎</span>
		<span>{fileName}</span>
		<em class="text-slate-500">{sizeText}</em>
	</span>
</a>
