---
type Props = {
	columns?: number;
	mobileColumns?: number;
	gapClass?: string;
	gap?: string;
};

const {
	columns = 2,
	mobileColumns = 1,
	gapClass = "gap-4",
	gap,
}: Props = Astro.props;

const desktopCols = Math.min(6, Math.max(1, Number(columns) || 2));
const mobileCols = Math.min(desktopCols, Math.max(1, Number(mobileColumns) || 1));

const mobileColClass = {
	1: "grid-cols-1",
	2: "grid-cols-2",
	3: "grid-cols-3",
	4: "grid-cols-4",
	5: "grid-cols-5",
	6: "grid-cols-6",
}[mobileCols];

const desktopColClass = {
	1: "md:grid-cols-1",
	2: "md:grid-cols-2",
	3: "md:grid-cols-3",
	4: "md:grid-cols-4",
	5: "md:grid-cols-5",
	6: "md:grid-cols-6",
}[desktopCols];

const inlineGap = typeof gap === 'string' && gap.trim() ? gap.trim() : undefined;
---

<div class:list={["grid", gapClass, mobileColClass, desktopColClass]} style={inlineGap ? `gap: ${inlineGap};` : undefined}>
	<slot />
</div>