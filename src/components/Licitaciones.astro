---
import { getCollection } from "astro:content";
import DataTable from "./DataTable.astro";

const entries = await getCollection("licitaciones");

const data = entries.map((entry) => {
	const slug = entry.id.replace(/\.(md|mdx)$/, "");

	return {
		title: entry.data.title,
		date: entry.data.date,
		type: entry.data.type,
		file: entry.data.file,
		href: encodeURI(`/transparencia/licitaciones/${slug}/`),
	};
});
---

<DataTable data={data} emptyMessage="No hay licitaciones publicadas en este momento." />
