---
import Layout from '../layouts/Layout.astro';
import FileCallout from './FileCallout.astro';
import PageHeader from './PageHeader.astro';
import { render, type CollectionEntry } from 'astro:content';

type DetailEntry =
	| CollectionEntry<'actas'>
	| CollectionEntry<'concursos'>
	| CollectionEntry<'licitaciones'>;

interface Props {
	entry: DetailEntry;
}

const { entry }: Props = Astro.props;
const { Content } = await render(entry);
const description = entry.data['descripci\u00f3n'];
const files = entry.data.files ?? [];
---

<Layout title={entry.data.title}>
	<main class="mx-auto max-w-[768px] px-4 py-8">
		<article class="markdown-content">
			<PageHeader title={entry.data.title} description={description} date={entry.data.date}>
				{files.length > 0 && (
					<section class="mt-4">
						{files.map((href) => (
							<FileCallout href={href} type={entry.data.type} />
						))}
					</section>
				)}
			</PageHeader>
			<Content />
		</article>
	</main>
</Layout>
