---
import { formatDateEs, formatDateEsShort } from '../utils/date';
import TypeBadge from './TypeBadge.astro';

type DataRow = {
	title: string;
	date: Date;
	type?: string;
	href?: string;
};

interface Props {
	data: DataRow[];
	emptyMessage?: string;
	showYearFilter?: boolean;
	heading?: string;
}

const { data, emptyMessage = 'No hay registros', showYearFilter = true, heading } = Astro.props;

const sortedData = [...data].sort((a, b) => b.date.getTime() - a.date.getTime());
const years = Array.from(new Set(sortedData.map((row) => row.date.getFullYear()))).sort((a, b) => b - a);
const latestYear = years[0];
---

{sortedData.length === 0 ? (
	<p>{emptyMessage}</p>
) : (
	<div data-data-table class="mt-4">
		{(showYearFilter || heading) && (
			<div class="mb-3 flex items-center justify-between gap-2">
				{heading ? <span class="text-base font-semibold text-slate-800">{heading}</span> : <span />}
				{showYearFilter && (
					<div class="flex items-center gap-2">
						<label class="text-sm font-medium text-slate-700" for="year-filter">Año</label>
						<select
							id="year-filter"
							data-year-select
							class="paper-surface rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-700 focus:border-slate-500 focus:outline-none"
						>
							{years.map((year) => (
								<option value={year} selected={year === latestYear}>{year}</option>
							))}
						</select>
					</div>
				)}
			</div>
		)}

		<div class="overflow-x-auto rounded-xl border border-slate-200">
			<table class="paper-surface min-w-full divide-y divide-slate-200 text-sm">
				<thead class="bg-slate-50">
					<tr>
						<th class="hidden w-px whitespace-nowrap px-4 py-3 text-left font-semibold text-slate-700 sm:table-cell">Tipo</th>
						<th class="hidden px-4 py-3 text-left font-semibold text-slate-700 sm:table-cell">Título</th>
						<th class="hidden px-4 py-3 text-left font-semibold text-slate-700 sm:table-cell">Fecha</th>
						<th class="px-4 py-3 text-left font-semibold text-slate-700 sm:hidden">Registro</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-100">
					{sortedData.map((row) => {
						const rowYear = row.date.getFullYear();
						const rowHref = row.href?.trim();

						return (
							<tr
								data-row
								data-year={rowYear}
								data-row-link={rowHref ? 'true' : undefined}
								class={`relative align-middle${showYearFilter && rowYear !== latestYear ? ' hidden' : ''}${rowHref ? ' cursor-pointer' : ''}`}
							>
								<td class="relative hidden w-px whitespace-nowrap px-4 py-3 sm:table-cell">
									{rowHref && (
										<a
											href={rowHref}
											aria-label={row.title}
											class="absolute inset-0 z-10 hidden rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-500 sm:block"
										/>
									)}
									<TypeBadge type={row.type} />
								</td>
								<td class="relative px-4 py-3 sm:hidden">
									{rowHref && (
										<a
											href={rowHref}
											aria-label={row.title}
											class="absolute inset-0 z-10 rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-500 sm:hidden"
										/>
									)}
									<div class="flex items-start justify-between gap-3">
										<TypeBadge type={row.type} />
										<span class="whitespace-nowrap text-xs font-medium uppercase tracking-wide text-slate-500">
											{formatDateEsShort(row.date)}
										</span>
									</div>
									<div class="mt-2 text-sm font-medium text-slate-900">{row.title}</div>
								</td>
								<td class="relative hidden px-4 py-3 font-medium text-slate-900 sm:table-cell">
									{rowHref && (
										<a
											href={rowHref}
											tabindex="-1"
											aria-hidden="true"
											class="absolute inset-y-0 z-10 hidden rounded-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-blue-500 sm:block"
											style="left: 0; right: 0;"
										/>
									)}
									{row.title}
								</td>
								<td class="relative hidden px-4 py-3 text-slate-600 sm:table-cell">
									{rowHref && (
										<a
											href={rowHref}
											tabindex="-1"
											aria-hidden="true"
											class="absolute inset-0 z-10 hidden rounded-sm sm:block"
										/>
									)}
									<span class="sm:hidden">{formatDateEsShort(row.date)}</span>
									<span class="hidden sm:inline">{formatDateEs(row.date)}</span>
								</td>
							</tr>
						);
					})}
				</tbody>
			</table>
		</div>

		<script is:inline>
			const tableRoot = document.currentScript?.closest('[data-data-table]');

			if (tableRoot) {
				const select = tableRoot.querySelector('[data-year-select]');
				const rows = tableRoot.querySelectorAll('tr[data-row]');
				const stripeClasses = ['paper-surface-soft', 'paper-surface'];

				const applyStriping = () => {
					let i = 0;
					rows.forEach((row) => {
						row.classList.remove(...stripeClasses);
						if (!row.classList.contains('hidden')) row.classList.add(stripeClasses[i++ % 2]);
					});
				};

				const applyFilter = (year) => {
					rows.forEach((row) => row.classList.toggle('hidden', row.getAttribute('data-year') !== year));
					applyStriping();
				};

				if (select instanceof HTMLSelectElement) {
					applyFilter(select.value);
					select.addEventListener('change', () => applyFilter(select.value));
				} else {
					applyStriping();
				}
			}
		</script>

		<style>
			[data-data-table] tr[data-row-link='true']:hover,
			[data-data-table] tr[data-row-link='true']:focus-within {
				background-color: rgb(241 245 249);
			}
		</style>
	</div>
)}
