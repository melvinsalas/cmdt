---
import { formatDateEs, formatDateEsShort } from '../utils/date';
import TypeBadge from './TypeBadge.astro';

type DataRow = {
	title: string;
	date: Date;
	type?: string;
	files?: string[];
	href?: string;
};

interface Props {
	data: DataRow[];
	emptyMessage?: string;
	showYearFilter?: boolean;
}

const { data, emptyMessage = 'No hay registros', showYearFilter = true } = Astro.props;

// Ordenar por fecha descendente
const sortedData = [...data].sort((a, b) => b.date.getTime() - a.date.getTime());
const years = Array.from(new Set(sortedData.map((row) => row.date.getFullYear()))).sort((a, b) => b - a);
const latestYear = years[0];
---

{sortedData.length === 0 ? (
	<p>{emptyMessage}</p>
) : (
	<div data-data-table>
		{showYearFilter && (
			<div class="mb-3 flex items-center justify-end gap-2">
				<label class="text-sm font-medium text-slate-700" for="year-filter">Año</label>
				<select
					id="year-filter"
					data-year-select
					class="rounded-md border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 focus:border-slate-500 focus:outline-none"
				>
					{years.map((year) => (
						<option value={year} selected={year === latestYear}>{year}</option>
					))}
				</select>
			</div>
		)}

		<div class="overflow-x-auto rounded-xl border border-slate-200">
			<table class="min-w-full divide-y divide-slate-200 bg-white text-sm">
				<thead class="bg-slate-50">
					<tr>
						{true && <th class="w-px whitespace-nowrap px-4 py-3 text-left font-semibold text-slate-700">Tipo</th>}
						<th class="px-4 py-3 text-left font-semibold text-slate-700">Título</th>
						<th class="px-4 py-3 text-left font-semibold text-slate-700">Fecha</th>
						<th class="w-px whitespace-nowrap px-4 py-3 text-left font-semibold text-slate-700"></th>
					</tr>
				</thead>
				<tbody class="divide-y divide-slate-100">
					{sortedData.map((row) => {
						const rowYear = row.date.getFullYear();
						const hiddenByDefault = showYearFilter && rowYear !== latestYear;

						return (
							<tr
								data-row
								data-year={rowYear}
								class={`align-middle${hiddenByDefault ? ' hidden' : ''}`}
							>
								<td class="w-px whitespace-nowrap px-4 py-3">
									<TypeBadge type={row.type} />
								</td>

								{/* Columna de título */}
								<td class="px-4 py-3 font-medium text-slate-900">{row.title}</td>

								{/* Columna de fecha */}
								<td class="px-4 py-3 text-slate-600">
									<span class="sm:hidden">{formatDateEsShort(row.date)}</span>
									<span class="hidden sm:inline">{formatDateEs(row.date)}</span>
								</td>

								{/* Columna de acción */}
								<td class="w-px whitespace-nowrap px-4 py-3">
									{row.files && row.files.length > 0 ? (
										row.files.length === 1 ? (
											<a
												class="text-blue-700 hover:underline"
												href={row.files[0]}
												target="_blank"
												rel="noopener noreferrer"
												title="Abrir en otra pestaña"
											>
												Archivo
											</a>
										) : (
											<div class="flex flex-wrap gap-2">
												{row.files.map((fileUrl, index) => (
													<a
														class="text-blue-700 hover:underline"
														href={fileUrl}
														target="_blank"
														rel="noopener noreferrer"
														title="Abrir en otra pestaña"
													>
														Archivo {index + 1}
													</a>
												))}
											</div>
										)
									) : row.href ? (
										<a class="text-blue-700 hover:underline" href={row.href}>
											Ver
										</a>
									) : null}
								</td>
							</tr>
						);
					})}
				</tbody>
			</table>
		</div>

		<script is:inline>
			const tableRoot = document.currentScript?.closest('[data-data-table]');

			if (tableRoot) {
				const select = tableRoot.querySelector('[data-year-select]');
				const rows = tableRoot.querySelectorAll('tr[data-row]');
				const rowStripeClasses = ['bg-white', 'bg-slate-50'];

				const applyRowStriping = () => {
					let visibleIndex = 0;

					rows.forEach((row) => {
						row.classList.remove(...rowStripeClasses);

						if (row.classList.contains('hidden')) {
							return;
						}

						row.classList.add(rowStripeClasses[visibleIndex % rowStripeClasses.length]);
						visibleIndex += 1;
					});
				};

				const applyYearFilter = (year) => {
					rows.forEach((row) => {
						const rowYear = row.getAttribute('data-year');
						row.classList.toggle('hidden', rowYear !== year);
					});

					applyRowStriping();
				};

				if (select instanceof HTMLSelectElement) {
					applyYearFilter(select.value);

					select.addEventListener('change', () => {
						applyYearFilter(select.value);
					});
				} else {
					applyRowStriping();
				}
			}
		</script>
	</div>
)}
