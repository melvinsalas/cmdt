---
import type { CollectionEntry } from 'astro:content';
import CollectionDetailPage from '../../../components/CollectionDetailPage.astro';
import { buildCollectionStaticPaths } from '../../../utils/collection-detail';

export async function getStaticPaths() {
	return buildCollectionStaticPaths('concursos');
}

interface Props {
	entry: CollectionEntry<'concursos'>;
}

const { entry } = Astro.props;
---

<CollectionDetailPage entry={entry} />
