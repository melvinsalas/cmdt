---
import Layout from '../../layouts/Layout.astro';

type ActaModule = {
	frontmatter?: {
		title?: string;
		date?: string;
		url?: string;
		type?: 'ordinaria' | 'extraordinaria';
	};
	url?: string;
};

const modules = Object.values(
	import.meta.glob('/src/pages/transparencia/actas/*.md', { eager: true })
) as ActaModule[];

const actas = modules
	.map((mod) => ({
		title: mod.frontmatter?.title ?? '',
		date: mod.frontmatter?.date ?? '',
		url: mod.frontmatter?.url ?? mod.url ?? '#',
		type: mod.frontmatter?.type,
	}))
	.filter((acta) => acta.title && acta.date && acta.url && acta.type)
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout>
	<main class="mx-auto max-w-3xl px-4 py-8">
		<h1 class="mb-6 text-2xl font-bold text-slate-900">Actas Municipales</h1>
		<ul class="space-y-3">
		{actas.map((acta) => (
			<li class="rounded-lg border border-slate-200 bg-white p-4 shadow-sm">
				<div class="flex flex-wrap items-center gap-2">
					<span
						class:list={[
							'inline-block rounded-full px-2 py-1 text-xs font-semibold capitalize',
							acta.type === 'ordinaria' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800',
						]}
					>
						{acta.type}
					</span>
					<strong class="text-slate-900">{acta.title}</strong>
				</div>
				<div class="mt-2 text-sm text-slate-600">{acta.date}</div>
				<a class="mt-2 inline-block text-sm text-blue-700 hover:underline" href={acta.url}>
					Ver archivo
				</a>
			</li>
		))}
		</ul>
	</main>
</Layout>
