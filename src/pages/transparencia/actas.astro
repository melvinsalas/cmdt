---
import Layout from '../../layouts/Layout.astro';
import ActaCard from '../../components/ActaCard.astro';

type ActaModule = {
	frontmatter?: {
		title?: string;
		date?: string;
		url?: string;
		type?: 'ordinaria' | 'extraordinaria';
	};
	url?: string;
};

type Acta = {
	title: string;
	date: string;
	url: string;
	type: 'ordinaria' | 'extraordinaria';
};

const modules = Object.values(
	import.meta.glob('/src/pages/transparencia/actas/*.md', { eager: true })
) as ActaModule[];

const actas = modules
	.map((mod) => ({
		title: mod.frontmatter?.title ?? '',
		date: mod.frontmatter?.date ?? '',
		url: mod.frontmatter?.url ?? mod.url ?? '#',
		type: mod.frontmatter?.type,
	}))
	.filter(
		(acta): acta is Acta =>
			Boolean(acta.title && acta.date && acta.url) &&
			(acta.type === 'ordinaria' || acta.type === 'extraordinaria')
	)
	.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout>
	<main class="mx-auto max-w-3xl px-4 py-8">
		<h1 class="mb-6 text-2xl font-bold text-slate-900">Actas Municipales</h1>
		<ul class="space-y-3">
		{actas.map((acta) => (
			<ActaCard title={acta.title} date={acta.date} url={acta.url} type={acta.type} />
		))}
		</ul>
	</main>
</Layout>
