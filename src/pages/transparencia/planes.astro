---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/MarkdownLayout.astro';

const planes = await getEntry('pages', 'planes');

if (!planes) {
	throw new Error('Planes page not found');
}

const { Content } = await render(planes);
---

<Layout title={planes.data.title}>
	<Content />
</Layout>
